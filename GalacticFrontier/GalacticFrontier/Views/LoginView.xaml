<UserControl x:Class="GalacticFrontier.Views.LoginView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:ctrl="clr-namespace:GalacticFrontier.Controls"
             xmlns:local="clr-namespace:GalacticFrontier"
             Background="{StaticResource BgBrush}">
  <Grid>
    <ctrl:StarfieldControl/>
    <Border Style="{StaticResource SciFiPanelBorder}" Width="400" Height="380"
            HorizontalAlignment="Center" VerticalAlignment="Center">
      <StackPanel>
        <TextBlock Style="{StaticResource SciFiTitle}" Text="{x:Static local:Strings.LoginHeader}" FontSize="18" Margin="0,0,0,16"/>
        <TextBlock Style="{StaticResource SciFiLabel}" Text="{x:Static local:Strings.Username}"/>
        <TextBox x:Name="UsernameBox" Style="{StaticResource SciFiTextBox}" Margin="0,4,0,12"
                 Text="{Binding Username, UpdateSourceTrigger=PropertyChanged}"/>
        <TextBlock Style="{StaticResource SciFiLabel}" Text="{x:Static local:Strings.Password}"/>
        <Grid Margin="0,4,0,12">
          <PasswordBox x:Name="PasswordBox" Style="{StaticResource SciFiPasswordBox}"
                       PasswordChanged="PasswordBox_OnPasswordChanged"/>
          <TextBox x:Name="PasswordVisible" Style="{StaticResource SciFiTextBox}"
                   Visibility="Collapsed" TextChanged="PasswordVisible_OnTextChanged"/>
          <Button HorizontalAlignment="Right" VerticalAlignment="Center" Margin="0,0,4,0"
                  Style="{StaticResource SciFiButton}" Padding="8,4" FontSize="10"
                  Content="👁" Command="{Binding TogglePasswordCommand}"/>
        </Grid>
        <TextBlock Style="{StaticResource SciFiError}" Text="{Binding ErrorMessage}"
                   Visibility="{Binding HasError, Converter={StaticResource BoolToVis}}"/>
        <TextBlock Style="{StaticResource SciFiError}" Text="{Binding LockoutText}"
                   Visibility="{Binding IsLockedOut, Converter={StaticResource BoolToVis}}"/>
        <Button Style="{StaticResource SciFiButton}" Content="{x:Static local:Strings.Confirm}"
                Margin="0,12,0,8" Command="{Binding LoginCommand}"/>
        <Button Style="{StaticResource SciFiButton}" Content="{x:Static local:Strings.Back}"
                Command="{Binding BackCommand}"/>
      </StackPanel>
    </Border>
  </Grid>
</UserControl>
