<UserControl x:Class="GalacticFrontier.Views.SignupView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:ctrl="clr-namespace:GalacticFrontier.Controls"
             xmlns:local="clr-namespace:GalacticFrontier"
             Background="{StaticResource BgBrush}">
  <Grid>
    <ctrl:StarfieldControl/>
    <Border Style="{StaticResource SciFiPanelBorder}" Width="420" Height="440"
            HorizontalAlignment="Center" VerticalAlignment="Center">
      <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel>
          <TextBlock Style="{StaticResource SciFiTitle}" Text="{x:Static local:Strings.SignupHeader}" FontSize="18" Margin="0,0,0,12"/>
          <TextBlock Style="{StaticResource SciFiLabel}" Text="{x:Static local:Strings.Username}"/>
          <TextBox Style="{StaticResource SciFiTextBox}" Margin="0,4,0,4"
                   Text="{Binding Username, UpdateSourceTrigger=PropertyChanged}"/>
          <TextBlock FontSize="11" Foreground="{StaticResource TextMutedBrush}" Text="{Binding UsernameHint}"/>
          <TextBlock Style="{StaticResource SciFiLabel}" Text="{x:Static local:Strings.Password}" Margin="0,8,0,0"/>
          <PasswordBox x:Name="Pw1" Style="{StaticResource SciFiPasswordBox}" Margin="0,4,0,8"
                       PasswordChanged="Pw1_OnPasswordChanged"/>
          <TextBlock Style="{StaticResource SciFiLabel}" Text="{x:Static local:Strings.ConfirmPassword}"/>
          <PasswordBox x:Name="Pw2" Style="{StaticResource SciFiPasswordBox}" Margin="0,4,0,8"
                       PasswordChanged="Pw2_OnPasswordChanged"/>
          <TextBlock Style="{StaticResource SciFiLabel}" Text="COMMANDER TITLE"/>
          <ComboBox Margin="0,4,0,12" ItemsSource="{Binding Titles}"
                    SelectedItem="{Binding CommanderTitle}"/>
          <TextBlock Style="{StaticResource SciFiError}" Text="{Binding ErrorMessage}"
                     Visibility="{Binding HasError, Converter={StaticResource BoolToVis}}"/>
          <Button Style="{StaticResource SciFiButton}" Content="{x:Static local:Strings.Enlist}"
                  Command="{Binding EnlistCommand}"/>
          <Button Style="{StaticResource SciFiButton}" Content="{x:Static local:Strings.Back}"
                  Margin="0,8,0,0" Command="{Binding BackCommand}"/>
        </StackPanel>
      </ScrollViewer>
    </Border>
  </Grid>
</UserControl>
