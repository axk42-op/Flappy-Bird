<UserControl x:Class="GalacticFrontier.Views.LauncherView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:ctrl="clr-namespace:GalacticFrontier.Controls"
             xmlns:local="clr-namespace:GalacticFrontier"
             Background="{StaticResource BgBrush}">
  <Grid>
    <ctrl:StarfieldControl/>
    <Border Style="{StaticResource SciFiPanelBorder}" Width="480" Height="320"
            HorizontalAlignment="Center" VerticalAlignment="Center">
      <StackPanel VerticalAlignment="Center">
        <TextBlock Style="{StaticResource SciFiTitle}" Text="{Binding Title}" FontSize="22" Margin="0,0,0,8"/>
        <TextBlock Style="{StaticResource SciFiSubtitle}" Text="{Binding Subtitle}" Margin="0,0,0,24"/>
        <Button Style="{StaticResource SciFiButton}" Content="{x:Static local:Strings.LaunchMission}"
                Width="240" Margin="0,6" HorizontalAlignment="Center"
                Command="{Binding LaunchCommand}"/>
        <Button Style="{StaticResource SciFiButton}" Content="{x:Static local:Strings.CreateAccount}"
                Width="240" Margin="0,6" HorizontalAlignment="Center"
                Command="{Binding SignupCommand}"/>
        <Button Style="{StaticResource SciFiButton}" Content="{x:Static local:Strings.Exit}"
                Width="240" Margin="0,6" HorizontalAlignment="Center"
                Command="{Binding ExitCommand}"/>
      </StackPanel>
    </Border>
    <DockPanel VerticalAlignment="Bottom" Margin="16,8">
      <TextBlock DockPanel.Dock="Left" FontFamily="{StaticResource HudFont}" FontSize="11"
                 Foreground="{StaticResource TextMutedBrush}" Text="v2.4.1 — Galactic Frontier WPF"/>
      <TextBlock DockPanel.Dock="Right" FontFamily="{StaticResource HudFont}" FontSize="11"
                 Foreground="{StaticResource SuccessBrush}" Text="{Binding StatusText}"/>
    </DockPanel>
  </Grid>
</UserControl>
